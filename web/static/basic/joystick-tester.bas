10 PRINT CHR$(147)
20 PRINT "    JOYSTICK TESTER"
30 PRINT "    ==============="
40 PRINT:PRINT "  JOY 1          JOY 2"
50 S=1024:C=55296
60 REM TL=TOP-LEFT TR=TOP-RIGHT BL=BOT-LEFT BR=BOT-RIGHT
70 TL=95:TR=105:BL=223:BR=233
80 REM JOY1 POSITIONS (UP,DOWN,LEFT,RIGHT,FIRE)
90 U1=S+205:D1=S+405:L1=S+283:R1=S+288:F1=S+285
100 REM JOY2 POSITIONS (+15 COLS)
110 U2=U1+15:D2=D1+15:L2=L1+15:R2=R1+15:F2=F1+15
120 REM DRAW UP ARROWS 
130 POKE U1,BR:POKE U1+1,BL
140 POKE U2,BR:POKE U2+1,BL
150 REM DRAW DOWN ARROWS 
160 POKE D1,TL:POKE D1+1,TR
170 POKE D2,TL:POKE D2+1,TR
180 REM DRAW LEFT 
190 POKE L1,BR:POKE L1+40,TL
200 POKE L2,BR:POKE L2+40,TL
210 REM DRAW RIGHT 
220 POKE R1,BL:POKE R1+40,TR
230 POKE R2,BL:POKE R2+40,TR
240 REM DRAW FIRE BUTTON (2X2 DIAMOND)
250 POKE F1,BR:POKE F1+1,BL:POKE F1+40,TL:POKE F1+41,TR
255 POKE F2,BR:POKE F2+1,BL:POKE F2+40,TL:POKE F2+41,TR
260 REM SET ALL TO GREY (12)
270 FOR I=0 TO 1
280 POKE C+U1-S+I,12:POKE C+D1-S+I,12
290 POKE C+U2-S+I,12:POKE C+D2-S+I,12
300 NEXT
310 POKE C+L1-S,12:POKE C+L1-S+40,12
320 POKE C+R1-S,12:POKE C+R1-S+40,12
330 POKE C+L2-S,12:POKE C+L2-S+40,12
340 POKE C+R2-S,12:POKE C+R2-S+40,12
350 POKE C+F1-S,12:POKE C+F1-S+1,12:POKE C+F1-S+40,12:POKE C+F1-S+41,12
355 POKE C+F2-S,12:POKE C+F2-S+1,12:POKE C+F2-S+40,12:POKE C+F2-S+41,12
360 REM MAIN LOOP
370 J1=PEEK(56321):J2=PEEK(56320)
380 REM JOY1 COLORS (12=GREY, 1=WHITE, 5=GREEN)
390 CO=12:IF(J1AND1)=0 THEN CO=1
400 POKE C+U1-S,CO:POKE C+U1-S+1,CO
410 CO=12:IF(J1AND2)=0 THEN CO=1
420 POKE C+D1-S,CO:POKE C+D1-S+1,CO
430 CO=12:IF(J1AND4)=0 THEN CO=1
440 POKE C+L1-S,CO:POKE C+L1-S+40,CO
450 CO=12:IF(J1AND8)=0 THEN CO=1
460 POKE C+R1-S,CO:POKE C+R1-S+40,CO
470 CO=12:IF(J1AND16)=0 THEN CO=5
480 POKE C+F1-S,CO:POKE C+F1-S+1,CO:POKE C+F1-S+40,CO:POKE C+F1-S+41,CO
490 REM JOY2 COLORS
500 CO=12:IF(J2AND1)=0 THEN CO=1
510 POKE C+U2-S,CO:POKE C+U2-S+1,CO
520 CO=12:IF(J2AND2)=0 THEN CO=1
530 POKE C+D2-S,CO:POKE C+D2-S+1,CO
540 CO=12:IF(J2AND4)=0 THEN CO=1
550 POKE C+L2-S,CO:POKE C+L2-S+40,CO
560 CO=12:IF(J2AND8)=0 THEN CO=1
570 POKE C+R2-S,CO:POKE C+R2-S+40,CO
580 CO=12:IF(J2AND16)=0 THEN CO=5
590 POKE C+F2-S,CO:POKE C+F2-S+1,CO:POKE C+F2-S+40,CO:POKE C+F2-S+41,CO
600 GOTO 370